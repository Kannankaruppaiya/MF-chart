# ─────────────────────────────────────────────────────────────────────────────
# Backend environment variables
# Copy this file to .env for local development, filling in real values.
# On your hosting platform (Render/Railway/Fly.io), set these in the dashboard.
# NEVER commit .env — only commit .env.example.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB connection string (used if any persistent storage is added later)
# Locally: mongodb://localhost:27017
MONGO_URL=

# MongoDB database name
DB_NAME=

# Comma-separated list of allowed CORS origins for the frontend.
# In production: https://your-app.vercel.app
# During development: * (allow all)
CORS_ORIGINS=
