# ─────────────────────────────────────────────────────────────────────────────
# Frontend environment variables
# Copy this file to .env for local development, filling in real values.
# In production (Vercel), set these under Project Settings → Environment Variables.
# NEVER commit .env — only commit .env.example.
# ─────────────────────────────────────────────────────────────────────────────

# URL of the deployed backend API (e.g. https://your-backend.onrender.com)
# Must NOT have a trailing slash.
# Locally: http://localhost:8001
REACT_APP_BACKEND_URL=

# (Optional) Webpack dev-server WebSocket port override — only needed locally.
# Leave blank or omit entirely in Vercel.
WDS_SOCKET_PORT=
